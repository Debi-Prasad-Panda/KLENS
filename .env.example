# ==================== K-LENS ENVIRONMENT VARIABLES ====================
# SECURITY WARNING: Never commit this file with real values to version control
# This is an example file. Copy it to .env and fill in your actual values.
# Make sure .env is in .gitignore

# Database
DB_PASSWORD=klens_secure_password_2024
DATABASE_URL=postgresql://klens_user:klens_secure_password_2024@postgres:5432/klens

# Redis
REDIS_URL=redis://redis:6379

# JWT (Legacy - not needed when using Supabase Auth)
# SECURITY: Use a strong random string (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=klens_jwt_secret_key_change_in_production_min_32_chars

# ==================== AI API KEYS ====================
# SECURITY: Never hard-code these in source files
# Get your keys from official provider websites

# Google Gemini AI - Required for embeddings and AI features
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API - Optional (for LLM completions)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# MQTT
MQTT_BROKER_URL=mqtt://mosquitto:1883

# Server
PORT=3000

# ==================== SUPABASE ====================
# Get your credentials from: https://app.supabase.com/project/_/settings/api

# Backend (Python) - Use service_role key for backend
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=raw_files

# Frontend (Vite) - Use anon key for frontend (public)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_URL=http://localhost:8000/api
