# Database
DB_PASSWORD=klens_secure_password_2024
DATABASE_URL=postgresql://klens_user:klens_secure_password_2024@postgres:5432/klens

# Redis
REDIS_URL=redis://redis:6379

# JWT (Legacy - not needed when using Supabase Auth)
JWT_SECRET=klens_jwt_secret_key_change_in_production_min_32_chars

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# MQTT
MQTT_BROKER_URL=mqtt://mosquitto:1883

# Server
PORT=3000
NODE_ENV=production

# ==================== SUPABASE ====================
# Get these from your Supabase Dashboard -> Settings -> API

# Backend (Python)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=raw_files

# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_URL=http://localhost:8000/api
